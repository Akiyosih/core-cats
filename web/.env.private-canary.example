# Temporary private-canary deployment environment
# Source references:
# - Core Blockchain project surface: https://coreblockchain.net/
# - Foxar toolchain intro: https://foxar.dev/intro/

NEXT_PUBLIC_LAUNCH_STATE=canary
NEXT_PUBLIC_SITE_SURFACE=private-canary
NEXT_PUBLIC_SITE_BASE_URL=https://replace-with-private-canary-origin
NEXT_PUBLIC_CORE_CHAIN_ID=1
CORE_NETWORK_ID=1
CORE_NETWORK_NAME=mainnet
NEXT_PUBLIC_CORE_EXPLORER_BASE_URL=https://blockindex.net
NEXT_PUBLIC_CORECATS_ADDRESS=replace-with-current-mainnet-rehearsal-corecats-address

CORECATS_BACKEND_MODE=proxy
# Prefer the local Contabo backend when the web app and mint backend share one host.
CORECATS_INTERNAL_BACKEND_BASE_URL=http://127.0.0.1:8787
# Optional external HTTPS backend origin if the canary web app is hosted elsewhere.
# CORECATS_BACKEND_BASE_URL=https://replace-with-private-canary-backend-origin
CORECATS_BACKEND_SHARED_SECRET=replace-with-the-same-random-secret-as-the-backend
CORECATS_RELAYER_ENABLED=true

# Optional but recommended when the private canary host also needs browse pages.
NEXT_PUBLIC_CORECATS_STATUS_URL=https://replace-with-public-status-origin/api/public/status
