# Copy the relevant values into the Vercel project environment for the production site.
# If you stage these values into a local file first, run:
#   node ./scripts/check-production-env.mjs ./.env.production.local
#
# Source references for the mainnet defaults used here:
# - RPC URL family: https://github.com/core-coin/foxar/blob/master/utils/src/rpc.rs
# - Blockindex mainnet base URL family: https://github.com/core-coin/corebc-rs/blob/master/corebc-core/src/types/network.rs

NEXT_PUBLIC_LAUNCH_STATE=closed
NEXT_PUBLIC_CORE_CHAIN_ID=1
CORE_NETWORK_ID=1
CORE_NETWORK_NAME=mainnet
NEXT_PUBLIC_CORE_EXPLORER_BASE_URL=https://blockindex.net

# Replace this after the real mainnet deploy exists.
NEXT_PUBLIC_CORECATS_ADDRESS=replace-with-mainnet-corecats-address

# Vercel keeps the public site and callback flow, while privileged mint actions proxy to Contabo.
CORECATS_BACKEND_MODE=proxy
CORECATS_BACKEND_BASE_URL=https://replace-with-contabo-backend-origin
CORECATS_BACKEND_SHARED_SECRET=replace-with-the-same-random-secret-as-contabo
CORECATS_RELAYER_ENABLED=true

# Rehearsal-canary wallet allowlisting is enforced on the Contabo backend, not on Vercel.
# Leave CORECATS_CANARY_ALLOWED_CORE_IDS unset here unless you intentionally need local-mode parity.
