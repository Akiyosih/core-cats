# Official CoreCats / CCAT mainnet deploy defaults.
# Keep secrets out of this file; stage deployer keystore/password and RPC separately.
#
# This file is for dry-run staging before the official broadcast deploy.
# It intentionally keeps the mainnet-label guard on and placeholder mode off.

CORECATS_COLLECTION_NAME=CoreCats
CORECATS_SYMBOL=CCAT
CORECATS_TOKEN_NAME_PREFIX=CoreCats
CORECATS_TOKEN_DESCRIPTION="CoreCats is a 1,000-piece fully on-chain 24x24 SVG cat collection on Core Blockchain, built from public code and fixed manifests."
CORECATS_ALLOW_NONSTANDARD_LABELS=0
CORECATS_SUPERRARE_PLACEHOLDER=0

EXPECTED_COLLECTION_NAME=CoreCats
EXPECTED_COLLECTION_SYMBOL=CCAT

MINT_CHAIN_ID=1
MINT_QUANTITY=1
