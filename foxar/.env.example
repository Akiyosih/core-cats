# Core Cats - Core testnet deploy environment template
# Copy this file to `.env` and fill real values.

# Required: Core testnet RPC URL
CORE_TESTNET_RPC_URL=https://xcbapi-arch-devin.coreblockchain.net/

# Required: Core/Foxar private key string
# Format: 57-byte key => 114 hex chars (0x prefix optional)
# Do NOT commit the real value.
DEPLOYER_PRIVATE_KEY=0x<REPLACE_WITH_114_HEX_CHARS>

# Optional: verifier settings (fill when verify step is ready)
VERIFIER_URL=
NETWORK=devin

# Optional: post-deploy check script inputs
CORECATS_ADDRESS=
EXPECTED_RENDERER_ADDRESS=
MINT_TO=
