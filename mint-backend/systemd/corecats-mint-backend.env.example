# Copy this file to the Contabo host, for example:
#   /etc/corecats-mint-backend.env
#
# Source references for the mainnet defaults used here:
# - RPC URL family: https://github.com/core-coin/foxar/blob/master/utils/src/rpc.rs
# - Blockindex mainnet base URL family: https://github.com/core-coin/corebc-rs/blob/master/corebc-core/src/types/network.rs

CORECATS_BACKEND_PROFILE=production
CORECATS_BACKEND_BIND=127.0.0.1
CORECATS_BACKEND_PORT=8787
CORECATS_BACKEND_DB_PATH=/var/lib/corecats-mint-backend/corecats-mint.db
CORECATS_BACKEND_SHARED_SECRET=replace-with-strong-random-secret
CORECATS_FINALIZE_WORKER_INTERVAL_SECONDS=5
CORECATS_FINALIZE_STUCK_TIMEOUT_SECONDS=180

# Optional rehearsal-canary gate. Leave unset for public launch.
# Provide a comma- or newline-separated list of allowed CorePass cb... addresses.
CORECATS_CANARY_ALLOWED_CORE_IDS=

# Prefer CORE_RPC_URL for mainnet deployment.
CORE_RPC_URL=https://xcbapi-arch-mainnet.coreblockchain.net/
CORE_CHAIN_ID=1
CORE_NETWORK_ID=1
CORE_NETWORK_NAME=mainnet
CORE_EXPLORER_BASE_URL=https://blockindex.net

# Set this only after the real mainnet CoreCats contract address exists.
CORECATS_ADDRESS=replace-with-mainnet-corecats-address

# Adjust these paths to the actual server checkout and Foxar installation.
CORECATS_FOXAR_DIR=/srv/core-cats/foxar
SPARK_PATH=/usr/local/bin/spark

# Keep deployer empty once the deploy window is over.
DEPLOYER_PRIVATE_KEY=

# Leave unset for the intended permissionless official CCAT path.
# Only set this if you intentionally keep a legacy signer-gated rehearsal flow alive.
MINT_SIGNER_PRIVATE_KEY=

# Finalizer can use either raw key mode or Foxar keystore mode.
# Raw key mode:
FINALIZER_PRIVATE_KEY=
#
# Keystore mode:
# For Core mainnet keystore broadcasts, keep the explicit cb... sender here so
# spark can use --wallet-network mainnet with the correct wallet address.
FINALIZER_ADDRESS=cb000000000000000000000000000000000000000000
FINALIZER_KEYSTORE_PATH=/srv/corecats-secrets/finalizer-mainnet.json
FINALIZER_PASSWORD_FILE=/srv/corecats-secrets/finalizer-mainnet.password
